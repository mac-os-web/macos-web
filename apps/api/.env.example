# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Gmail OAuth redirect URI (must match Google Cloud Console)
# Local dev: http://localhost:5173/api/gmail/callback
GMAIL_OAUTH_REDIRECT_URI=http://localhost:5173/api/gmail/callback

# Gmail OAuth scopes (comma-separated)
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send

# Token encryption key: base64-encoded 32-byte random key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GMAIL_TOKEN_ENCRYPTION_KEY=

# Frontend origin for CORS (comma-separated)
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Database (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_URL_MIGRATION=postgresql://user:password@db.<project-ref>.supabase.co:5432/postgres
DATABASE_SSL=true
# Set to "false" only if your DB uses a self-signed certificate
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Session
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=false

# Server
PORT=8080
NODE_ENV=development
